# Database — PostgreSQL connection string.
# Vercel Postgres: use the pooled "Prisma" URL. Neon/Supabase also work.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Anthropic API key — enables LLM-powered knowledge-base structuring.
# Without it, the app falls back to heuristic extraction (lower quality).
ANTHROPIC_API_KEY=""

# Model used for structuring scraped content (default: claude-sonnet-4-6)
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Max internal pages to crawl per site
SCRAPE_MAX_PAGES="10"

# Public base URL used when generating customer onboarding links (Phase 4).
# Leave empty in dev to derive from the request host.
APP_URL=""

# Secret used to sign customer session tokens (Phase 6). Set a long random
# value in production.
AUTH_SECRET="dev-insecure-secret-change-me"
